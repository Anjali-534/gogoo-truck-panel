# truck-panel — required environment variables (placeholders only, no real values)

# Backend API base URL (public — exposed to the browser by design)
NEXT_PUBLIC_API_URL=https://your-backend.example.com

# Ola Maps (Krutrim) client key — map tiles/autocomplete (public client key)
NEXT_PUBLIC_OLA_MAPS_KEY=your_ola_maps_api_key_here

# Panel identity shown in the UI
NEXT_PUBLIC_PANEL_NAME=Truck Panel
NEXT_PUBLIC_PANEL_TYPE=truck
